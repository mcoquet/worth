{
  "$schema": "https://raw.githubusercontent.com/nicknisi/dotfiles/main/config/tauri/tauri.conf.schema.json",
  "productName": "Worth",
  "version": "0.2.1-alpha.5",
  "identifier": "com.worth.desktop",
  "build": {
    "frontendDist": "dist",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Worth",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:4090 ws://127.0.0.1:4090; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "version": "0.2.1.5"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
